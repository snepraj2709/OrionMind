# Public browser configuration. Never add a secret or service-role key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Real backend origin, without a trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_REFLECTIONS_ENABLED=false

# Playwright only. These values are never exposed through the browser bundle.
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=
