ENVIRONMENT="development"
ENABLE_API_DOCS="true"

SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
APP_DATABASE_URL=""
WORKER_DATABASE_URL=""
# Live E2E test instrumentation only; queries are forced into read-only transactions.
ADMIN_APP_DATABASE_URL=""
# Controlled migration runner only; use a migration-owner URL, never an application role.
ORION_MIGRATION_DATABASE_URL=""

OPENAI_API_KEY=""
OPENAI_ENTRY_ANALYSIS_MODEL="gpt-5.6-luna"
OPENAI_REFLECTION_SYNTHESIS_MODEL="gpt-5.6-terra"
OPENAI_REFLECTION_CRITIC_MODEL="gpt-5.6-sol"
OPENAI_CONNECT_TIMEOUT_SECONDS="10"
OPENAI_RESPONSE_TIMEOUT_SECONDS="60"
PROCESSING_TOTAL_TIMEOUT_SECONDS="300"
ENTRY_ENCRYPTION_ACTIVE_KEY_ID="orion-entry-2026-01"
ENTRY_ENCRYPTION_KEYS='{"orion-entry-2026-01":"REPLACE_WITH_PADDED_BASE64_32_BYTE_KEY"}'
ENTRY_FINGERPRINT_ACTIVE_KEY_ID="orion-fingerprint-2026-01"
ENTRY_FINGERPRINT_KEYS='{"orion-fingerprint-2026-01":"REPLACE_WITH_PADDED_BASE64_32_BYTE_KEY"}'
REFLECTION_REVIEW_THRESHOLD="0.80"

CORS_ALLOW_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:3100,http://localhost:8080,http://localhost:5173"
REQUEST_TIMEOUT_SECONDS="30"
MAX_REQUEST_BODY_BYTES="1048576"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="5"
DATABASE_POOL_RECYCLE_SECONDS="300"
STARTUP_READINESS_TIMEOUT_SECONDS="10"
PROCESSING_JOB_POLL_SECONDS="1"
PROCESSING_JOB_HEARTBEAT_SECONDS="30"
PROCESSING_JOB_STALE_SECONDS="300"
PROCESSING_JOB_RECOVERY_INTERVAL_SECONDS="60"
PROCESSING_BACKFILL_MAX_QUEUE_DEPTH="1000"
PROCESSING_BACKFILL_MAX_OLDEST_PENDING_SECONDS="300"
REFLECTION_ENGINE_ENABLED="false"
REFLECTION_SCHEDULER_ENABLED="false"
REFLECTION_API_ENABLED="false"
REFLECTION_ROLLOUT_MODE="off"
REFLECTION_ROLLOUT_USER_IDS=""
REFLECTION_SCHEDULER_POLL_SECONDS="60"
REFLECTION_BASIS_DAYS="90"
# In-process rate limits are correct only for one instance and one web worker.
WEB_CONCURRENCY="1"
RATE_LIMITING_ENABLED="true"
LOG_FORMAT="json"
OTEL_ENABLED="false"
OTEL_SERVICE_NAME="orion-backend"
# OTEL_EXPORTER_OTLP_ENDPOINT="https://collector.example:4317"

# Test-only two-account proof credentials. Never use a shared/production project.
SUPABASE_TEST_EMAIL=""
SUPABASE_TEST_PASSWORD=""
SUPABASE_TEST_OTHER_EMAIL=""
SUPABASE_TEST_OTHER_PASSWORD=""
# Local disposable PostgreSQL proof only; test code rejects remote hosts and other database names.
STAGE2_DISPOSABLE_DATABASE_URL=""
